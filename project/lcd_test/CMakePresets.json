{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "clang",
      "displayName": "Clang + Ninja",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/clang-ninja",
      "toolchainFile": "${sourceDir}/cmake/toolchains/clang-arm-none-eabi.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "firmware",
      "configurePreset": "clang",
      "targets": [
        "firmware"
      ]
    },
    {
      "name": "download",
      "configurePreset": "clang",
      "targets": [
        "download"
      ]
    }
  ]
}
