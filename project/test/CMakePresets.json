{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "clang-ninja",
      "displayName": "Clang + Ninja",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/clang-ninja",
      "toolchainFile": "${sourceDir}/../blink/cmake/toolchains/clang-arm-none-eabi.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "test",
      "configurePreset": "clang-ninja",
      "targets": [
        "test"
      ]
    },
    {
      "name": "test_flash",
      "configurePreset": "clang-ninja",
      "targets": [
        "test_flash"
      ]
    }
  ]
}
